{
  "name": "proxy-acpx-x",
  "version": "1.7.0",
  "description": "ACP adapters for Claude Code, Codex, and Gemini CLI — proxy-acpx-x where x is the CLI name",
  "main": "dist/adapter.js",
  "types": "dist/adapter.d.ts",
  "bin": {
    "proxy-acpx-claude": "dist/adapter.js",
    "proxy-acpx-codex": "dist/codex-adapter.js",
    "proxy-acpx-gemini": "dist/gemini-adapter.js",
    "proxy-acpx-server": "dist/http-server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "start": "node dist/http-server.js",
    "start:acp": "node dist/adapter.js",
    "dev": "ts-node src/adapter.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "bash test/smoke.sh",
    "test:smoke:claude": "bash test/smoke.sh claude",
    "test:smoke:codex": "bash test/smoke.sh codex"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clonn/proxy-acpx-x.git"
  },
  "homepage": "https://github.com/clonn/proxy-acpx-x#readme",
  "bugs": {
    "url": "https://github.com/clonn/proxy-acpx-x/issues"
  },
  "keywords": [
    "claude-code",
    "acp",
    "acpx",
    "openclaw",
    "adapter",
    "proxy",
    "stream-json"
  ],
  "author": "Caesar Chi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
